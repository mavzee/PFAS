# Fastest: Sheet ID + Google Sheets API key (reads live data, no publish delay)
# Also keys the shared Firestore Recent Activity document (recentActivityFeeds/{sheetId})
VITE_GOOGLE_SHEET_ID=1m9JYTqENHS3w1_HNT6pGlqrcLcGHok4VZuah4rePY8M
VITE_GOOGLE_SHEETS_API_KEY=AIzaSyDZZYdQHHZ0dPMcZhGXdC6BAagx5iAj0K0
# Optional: VITE_GOOGLE_SHEET_RANGE='Sheet1'!A:Z
# Optional: VITE_GOOGLE_SHEET_GID=0

# Tester Activity tab (headers: Tester, Status, Current Location, Last Activity)
VITE_GOOGLE_SHEET_TESTER_TAB=Tester Activity
# Required without API key: publish ONLY the "Tester Activity" tab to web (CSV) and paste that URL here
VITE_GOOGLE_SHEET_TESTER_CSV_URL=
# Or set the tab gid from the sheet URL when on the Tester Activity tab (API key is easier)
VITE_GOOGLE_SHEET_TESTER_GID=

# Fallback: published CSV URL (slower — Google can delay updates by minutes)
VITE_GOOGLE_SHEET_CSV_URL=https://docs.google.com/spreadsheets/d/e/2PACX-1vTzwAXVri6pd2du5LLeP1IiBncrnwz5QfGz5sxkuXbtGeXgf_nRlwCPpb6lWoX7Fi-he9v3sCYrJlnT/pub?gid=0&single=true&output=csv

# Poll interval in ms (default: 1000 with API key, 5000 for published CSV only)
VITE_GOOGLE_SHEET_POLL_MS=1000

# Live Map: bias Nominatim geocoding for Company Name (ISO country code, e.g. us)
VITE_GEOCODE_COUNTRY=us
VITE_FIREBASE_API_KEY=AIzaSyDNsx6DsPF4fnyyv33mrHfIHpT6Mt0V0_A
VITE_FIREBASE_AUTH_DOMAIN=pfas-lawg.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=pfas-lawg
VITE_FIREBASE_STORAGE_BUCKET=pfas-lawg.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=546337410776
VITE_FIREBASE_APP_ID=1:546337410776:web:8daff269941a012b5f91ad